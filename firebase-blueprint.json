{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stores student profile and learning statistics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "retentionScore": { "type": "number", "description": "0-100 score of student retention" },
        "totalStudyHours": { "type": "number", "description": "Total hours studied across all subjects" },
        "subjectHours": { "type": "object", "description": "Map of subjectId to hours studied" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "Records of AI tutor interactions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "messages": { "type": "array" }
      }
    },
    "MockTest": {
      "title": "MockTest",
      "description": "Generated quizzes and student results.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/study_sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "AI chat history"
    },
    "/mock_tests/{testId}": {
      "schema": "MockTest",
      "description": "Quiz results"
    }
  }
}
